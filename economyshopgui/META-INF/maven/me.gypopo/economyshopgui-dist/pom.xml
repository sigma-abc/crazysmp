         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <artifactId>economyshopgui-dist</artifactId>
    <packaging>jar</packaging>

    <parent>
        <groupId>me.gypopo</groupId>
        <artifactId>economyshopgui-parent</artifactId>
        <version>${revision}</version>
    </parent>

    <profiles>
        <profile>
            <id>public</id>

            <build>
                <directory>../target</directory>
                <finalName>EconomyShopGUI-${project.version}</finalName>
                <plugins>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-shade-plugin</artifactId>
                        <version>3.6.1</version>
                        <executions>
                            <execution>
                                <phase>package</phase>
                                <goals>
                                    <goal>shade</goal>
                                </goals>
                                <configuration>
                                    <artifactSet>
                                        <includes>
                                            <include>me.gypopo:economyshopgui-*</include>
                                            <include>me.gypopo:coinsenginev1</include>
                                            <include>me.gypopo:coinsenginev2</include>
                                            <include>me.gypopo:coinsenginev3</include>
                                            <include>me.gypopo:coinsenginev4</include>
                                        </includes>
                                    </artifactSet>
                                    <transformers>
                                        <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                                            <manifestEntries>
                                                <paperweight-mappings-namespace>spigot</paperweight-mappings-namespace >
                                            </manifestEntries>
                                        </transformer>
                                    </transformers>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
        <profile>
            <id>nitro-setups</id>
            <properties>
                <!-- override coordinates so private artifact is distinct -->
                <project.artifactId>${project.artifactId}-nitro-setups</project.artifactId>
                <project.version>${project.version}-nitro-setups</project.version>
            </properties>

            <build>
                <directory>../target</directory>
                <finalName>EconomyShopGUI-NitroSetups-${project.version}</finalName>
                <plugins>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-shade-plugin</artifactId>
                        <version>3.6.1</version>
                        <executions>
                            <execution>
                                <phase>package</phase>
                                <goals>
                                    <goal>shade</goal>
                                </goals>
                                <configuration>
                                    <artifactSet>
                                        <includes>
                                            <include>me.gypopo:economyshopgui-*</include>
                                            <include>me.gypopo:coinsenginev1</include>
                                            <include>me.gypopo:coinsenginev2</include>
                                            <include>me.gypopo:coinsenginev3</include>
                                            <include>me.gypopo:coinsenginev4</include>
                                        </includes>
                                    </artifactSet>
                                    <transformers>
                                        <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                                            <manifestEntries>
                                                <paperweight-mappings-namespace>spigot</paperweight-mappings-namespace >
                                            </manifestEntries>
                                        </transformer>
                                    </transformers>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>

